<Window x:Class="EbookDiff.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:EbookDiff.Models"
        Title="EbookDiff · 电子书版本对比"
        Height="720" Width="1100"
        Background="White"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- 极简黑白主题 -->
        <Style x:Key="HeaderLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PathBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="Black"/>
        </Style>

        <Style x:Key="PickButton" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="28,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- 差异行模板：标记 | 书A | 书B -->
        <DataTemplate x:Key="DiffRowTemplate" DataType="{x:Type models:DiffRow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 分隔线（差异行用黑线，普通行用浅灰） -->
                <Border Grid.ColumnSpan="3" VerticalAlignment="Bottom" Height="1"
                        Background="{Binding Divider}"/>

                <!-- 行首标记 -->
                <TextBlock Grid.Column="0"
                           Text="{Binding Marker}"
                           FontFamily="Consolas"
                           FontSize="14"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           Margin="0,6,0,6"
                           Foreground="Black"/>

                <!-- 书籍 A -->
                <Border Grid.Column="1"
                        Background="{Binding LeftBackground}"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                    <TextBlock Text="{Binding LeftText}"
                               Foreground="{Binding LeftForeground}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="8,6"/>
                </Border>

                <!-- 书籍 B -->
                <Border Grid.Column="2"
                        Background="{Binding RightBackground}">
                    <TextBlock Text="{Binding RightText}"
                               Foreground="{Binding RightForeground}"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Margin="8,6"/>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <DockPanel Background="White">

        <!-- 标题栏 -->
        <Border DockPanel.Dock="Top" Background="Black" Padding="20,12">
            <TextBlock Text="E B O O K D I F F" Foreground="White" FontWeight="Bold" FontSize="16"/>
        </Border>

        <!-- 控制栏：两本书选择 + 对比按钮 -->
        <Border DockPanel.Dock="Top" Background="White"
                BorderBrush="Black" BorderThickness="0,0,0,1" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="书籍 A" Style="{StaticResource HeaderLabel}" Margin="0,0,8,0"/>
                <TextBox  Grid.Column="1" x:Name="PathABox" Style="{StaticResource PathBox}"/>
                <Button   Grid.Column="2" x:Name="PickA" Content="选择…" Style="{StaticResource PickButton}" Click="PickA_Click" Margin="8,0,0,0"/>

                <TextBlock Grid.Column="4" Text="书籍 B" Style="{StaticResource HeaderLabel}"/>
                <TextBox  Grid.Column="5" x:Name="PathBBox" Style="{StaticResource PathBox}" Margin="8,0,0,0"/>
                <Button   Grid.Column="6" x:Name="PickB" Content="选择…" Style="{StaticResource PickButton}" Click="PickB_Click" Margin="8,0,0,0"/>

                <Button   Grid.Column="8" x:Name="CompareBtn" Content="对  比" Style="{StaticResource PrimaryButton}" Click="Compare_Click"/>
            </Grid>
        </Border>

        <!-- 状态条 -->
        <Border DockPanel.Dock="Top" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="20,6">
            <TextBlock x:Name="StatusText" Text="就绪。请选择两本电子书。" FontSize="12" Foreground="Black"/>
        </Border>

        <!-- 主区：差异列表 -->
        <ScrollViewer Background="White" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="DiffList" ItemTemplate="{StaticResource DiffRowTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
